<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="@color/material_dynamic_neutral90">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="so thu 1"
            android:textSize="18dp"
            android:textColor="@color/material_dynamic_neutral40"
            />
        <EditText
            android:id="@+id/edt1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="moi nhap so "/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="@color/material_dynamic_neutral90">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="so thu 2"
            android:textSize="18dp"
            android:textColor="@color/material_dynamic_neutral40"
            />
        <EditText
            android:id="@+id/edt2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="moi nhap so "/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:gravity="center_horizontal"
        android:background="@color/material_dynamic_neutral90">
        <Button
            android:id="@+id/btnCong"
            android:layout_margin="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:onClick="XuLyCong"/>

        <Button
            android:id="@+id/btntru"
            android:layout_margin="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="XuLyTru"
            android:text="-"/>
        <Button
            android:id="@+id/btnNhan"
            android:layout_margin="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="XuLyNhan"
            android:text="*"/>
        <Button
            android:id="@+id/btnChia"
            android:layout_margin="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="XuLyChia"
            android:text="/"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="@color/material_dynamic_neutral90">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Keet qua la "
            android:textSize="18dp"
            android:textColor="@color/material_dynamic_neutral40"
            />
        <EditText
            android:id="@+id/edtKq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:hint="noi nhan ket qua "/>
    </LinearLayout>

</LinearLayout>